NODE_ENV=development
PORT=5000
APP_NAME=SafeSpeak Backend
APP_VERSION=1.0.0
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=
MONGODB_URI=mongodb://localhost:27017/safespeak
MONGODB_DNS_SERVERS=
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
BCRYPT_SALT_ROUNDS=12
EVIDENCE_LOCAL_STORAGE_PATH=./storage/evidence
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_AUDIT_SIGNING_KEY=
EVIDENCE_MAX_FILE_SIZE_BYTES=10485760
CONTENT_RESOURCE_STORAGE_PATH=./storage/content-resources
CONTENT_RESOURCE_MAX_FILE_SIZE_BYTES=52428800
MICRO_EDUCATION_IMAGE_STORAGE_PATH=./storage/microeducation-images
MICRO_EDUCATION_IMAGE_MAX_FILE_SIZE_BYTES=10485760
MICRO_EDUCATION_S3_BUCKET=
MICRO_EDUCATION_S3_PREFIX=microeducation-images
MICRO_EDUCATION_CDN_BASE_URL=
MEDIA_ASSET_STORAGE_PATH=./storage/media-assets
MEDIA_ASSET_MAX_FILE_SIZE_BYTES=2097152
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
SCAMSHIELD_URLHAUS_AUTH_KEY=
SCAMSHIELD_SAFE_BROWSING_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
ASR_MAX_FILE_SIZE_BYTES=26214400
RAG_VECTOR_INDEX=rag_chunks_vector_index

# Pinecone is optional at startup. It is required for Pinecone-backed indexing/search.
# The Pinecone index must already exist before running ingestion.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large requires index dimension 3072.
# Use cosine as the Pinecone index metric.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=safespeak-legislation-dev
PINECONE_NAMESPACE=dev
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
INTERNAL_KNOWLEDGE_DIR=knowledge/internal
ENABLE_INTERNAL_KNOWLEDGE_AUTO_APPROVE=true
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EVIDENCE_S3_BUCKET=
EVIDENCE_S3_PREFIX=evidence-vault
REPORT_DELIVERY_EXPORT_PATH=./storage/report-delivery
DELIVERY_API_TIMEOUT_MS=15000
DELIVERY_API_BEARER_TOKEN=
DELIVERY_EMAIL_WEBHOOK_URL=
DELIVERY_EMAIL_WEBHOOK_TOKEN=
ENABLE_ADMIN_SEED=false
DEFAULT_SUPER_ADMIN_EMAIL=
DEFAULT_SUPER_ADMIN_PASSWORD=
DEFAULT_SUPER_ADMIN_FULL_NAME=SafeSpeak Super Admin
